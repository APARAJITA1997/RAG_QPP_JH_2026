
"""
src/adaptive_rag.py
-------------------
QPP-guided adaptive RAG pipeline.
 
Adaptive policy: A(q) = (k(q), λ(q))
  - k(q)  : retrieval depth, controlled by QPP score thresholds
  - λ(q)  : context-influence weight ∈ [0, 1], derived from QPP score via sigmoid
             scaling. Controls how strongly the retrieved context is foregrounded
             in the generation prompt:
               λ > 0.66  → "HIGH"   context influence  (retrieval is trusted)
               λ ∈ [0.33, 0.66] → "MEDIUM" context influence (balanced)
               λ < 0.33  → "LOW"    context influence  (model's parametric
                                     knowledge takes precedence)
 
The mapping from QPP score s ∈ [0,1] to both policy components:
 
    k(q)  = k_min + round((k_max - k_min) * s)
    λ(q)  = sigmoid(α * (s - 0.5))          # α=6 gives a smooth S-curve
 
References
----------
See paper Section 4.3 (Adaptive Retrieval Policy) for the formal definition.
"""
 
from __future__ import annotations
 
import logging
import math
from dataclasses import dataclass, field
from typing import Callable, List, Optional
 
import numpy as np
 
logger = logging.getLogger(__name__)
 
# ── Constants ─────────────────────────────────────────────────────────────────
 
_SIGMOID_ALPHA = 6.0   # steepness of the λ S-curve
_K_MIN = 5             # minimum retrieval depth
_K_MAX = 20            # maximum retrieval depth
 
# λ thresholds that define the three prompt regimes
_LAMBDA_HIGH = 0.66
_LAMBDA_LOW  = 0.33
 
 
# ══════════════════════════════════════════════════════════════════════════════
# Result dataclass
# ══════════════════════════════════════════════════════════════════════════════
 
@dataclass
class RAGResult:
    query:     str
    qpp_score: float
    k_used:    int
    lambda_q:  float          # ← NEW: context-influence weight
    context_influence: str    # ← NEW: "HIGH" | "MEDIUM" | "LOW" (human-readable)
    answer:    str
    rouge_l:   float = 0.0
    bert_f1:   float = 0.0
    token_f1:  float = 0.0
 
 
# ══════════════════════════════════════════════════════════════════════════════
# Policy functions
# ══════════════════════════════════════════════════════════════════════════════
 
def compute_lambda(qpp_score: float, alpha: float = _SIGMOID_ALPHA) -> float:
    """
    Map a QPP score ∈ [0, 1] to a context-influence weight λ ∈ (0, 1)
    via a sigmoid centred at 0.5.
 
    A higher QPP score means the retriever is estimated to be effective
    for this query, so retrieved context should be weighted more heavily.
 
    Parameters
    ----------
    qpp_score : float
        Predicted retrieval effectiveness, output of the QPP model.
    alpha : float
        Sigmoid steepness (default 6.0).
 
    Returns
    -------
    float
        λ(q) ∈ (0, 1)
    """
    return 1.0 / (1.0 + math.exp(-alpha * (qpp_score - 0.5)))
 
 
def compute_k(qpp_score: float,
              k_min: int = _K_MIN,
              k_max: int = _K_MAX) -> int:
    """
    Map a QPP score ∈ [0, 1] to a retrieval depth k ∈ [k_min, k_max].
 
    Parameters
    ----------
    qpp_score : float
    k_min, k_max : int
        Depth boundaries.
 
    Returns
    -------
    int
        k(q)
    """
    return k_min + round((k_max - k_min) * float(qpp_score))
 
 
def lambda_to_influence(lambda_q: float) -> str:
    """Return a human-readable label for the λ regime."""
    if lambda_q >= _LAMBDA_HIGH:
        return "HIGH"
    elif lambda_q >= _LAMBDA_LOW:
        return "MEDIUM"
    else:
        return "LOW"
 
 
# ══════════════════════════════════════════════════════════════════════════════
# Prompt builder
# ══════════════════════════════════════════════════════════════════════════════
 
def build_prompt(query: str, context: str, lambda_q: float) -> str:
    """
    Construct a generation prompt whose phrasing reflects λ(q).
 
    The three regimes operationalise λ as follows:
 
    HIGH   (λ ≥ 0.66): Instructs the model to treat the retrieved passages as
                        the primary (and authoritative) source. This applies
                        when the QPP score is high, meaning retrieval quality
                        is estimated to be good.
 
    MEDIUM (0.33 ≤ λ < 0.66): Instructs the model to use the passages as
                        supplementary evidence while drawing on its own
                        knowledge where the passages are insufficient.
 
    LOW    (λ < 0.33):  Instructs the model to answer primarily from
                        parametric knowledge and treat the retrieved context
                        only as weak background. Applies when retrieval quality
                        is estimated to be poor.
 
    Parameters
    ----------
    query   : str
    context : str   — concatenated retrieved passage texts
    lambda_q : float — λ(q) value
 
    Returns
    -------
    str
        Formatted prompt string.
    """
    influence = lambda_to_influence(lambda_q)
 
    if influence == "HIGH":
        instruction = (
            "The following retrieved passages are highly relevant to the query. "
            "Base your answer primarily on this context and cite it where appropriate."
        )
    elif influence == "MEDIUM":
        instruction = (
            "The following passages may be partially relevant. "
            "Use them as supporting evidence, but supplement with your own knowledge "
            "where the passages are insufficient or ambiguous."
        )
    else:  # LOW
        instruction = (
            "The retrieved passages below may have limited relevance to this query. "
            "Answer primarily from your own knowledge; treat the context as weak "
            "background information only."
        )
 
    prompt = (
        f"{instruction}\n\n"
        f"Context (λ={lambda_q:.3f}):\n{context}\n\n"
        f"Question: {query}\n\n"
        f"Answer:"
    )
    return prompt
 
 
# ══════════════════════════════════════════════════════════════════════════════
# Pipeline
# ══════════════════════════════════════════════════════════════════════════════
 
class AdaptiveRAGPipeline:
    """
    End-to-end QPP-guided adaptive RAG pipeline.
 
    For each query q the pipeline:
    1. Extracts QPP features and predicts a score s = QPP(q).
    2. Derives the adaptive policy A(q) = (k(q), λ(q)):
         k(q)  = compute_k(s)       → retrieval depth
         λ(q)  = compute_lambda(s)  → context-influence weight
    3. Retrieves the top-k(q) passages.
    4. Builds a λ-conditioned prompt via build_prompt().
    5. Generates an answer and (optionally) evaluates it.
 
    Parameters
    ----------
    retriever    : object with .retrieve(query, top_k) → List[dict]
    generator    : object with .generate(prompt) → str
    qpp_model    : fitted sklearn-compatible QPP model
    scaler       : fitted sklearn StandardScaler (or None)
    df_lookup    : dict, term → document frequency
    corpus_lm    : dict, term → corpus probability
    query_emb_fn : callable or None, encodes a query string → np.ndarray
    k_min, k_max : int, retrieval depth bounds
    """
 
    def __init__(
        self,
        retriever,
        generator,
        qpp_model,
        scaler=None,
        df_lookup: dict | None = None,
        corpus_lm: dict | None = None,
        query_emb_fn: Optional[Callable] = None,
        k_min: int = _K_MIN,
        k_max: int = _K_MAX,
    ):
        self.retriever    = retriever
        self.generator    = generator
        self.qpp_model    = qpp_model
        self.scaler       = scaler
        self.df_lookup    = df_lookup or {}
        self.corpus_lm    = corpus_lm or {}
        self.query_emb_fn = query_emb_fn
        self.k_min        = k_min
        self.k_max        = k_max
 
    # ── Internal helpers ──────────────────────────────────────────────────────
 
    def _predict_qpp(self, query: str) -> float:
        """
        Retrieve a fixed-depth candidate set, extract features, and return
        the QPP score for the query.
        """
        from src.features import extract_features_batch
 
        results    = self.retriever.retrieve(query, top_k=self.k_max)
        texts      = [r["text"] for r in results]
        embs       = np.stack([r["embedding"] for r in results])
        q_emb      = (
            self.query_emb_fn(query)
            if self.query_emb_fn is not None
            else np.zeros(768, dtype=np.float32)
        )
 
        X = extract_features_batch(
            [query], [texts], [embs],
            q_emb[np.newaxis, :],
            self.df_lookup, self.corpus_lm,
        )
 
        if self.scaler is not None:
            X = self.scaler.transform(X)
 
        score = float(self.qpp_model.predict(X)[0])
        # Clip to [0, 1] in case model output drifts slightly outside
        return float(np.clip(score, 0.0, 1.0))
 
    def _evaluate(self, prediction: str, reference: str) -> dict:
        """Compute ROUGE-L, BERTScore F1, and token-level F1."""
        rouge_l  = 0.0
        bert_f1  = 0.0
        token_f1 = 0.0
 
        try:
            from rouge_score import rouge_scorer as rs
            scorer  = rs.RougeScorer(["rougeL"], use_stemmer=True)
            rouge_l = scorer.score(reference, prediction)["rougeL"].fmeasure
        except Exception:
            pass
 
        try:
            from bert_score import score as bscore
            _, _, F = bscore([prediction], [reference], lang="en", verbose=False)
            bert_f1 = float(F[0])
        except Exception:
            pass
 
        # Token-level F1
        pred_tokens = set(prediction.lower().split())
        ref_tokens  = set(reference.lower().split())
        if pred_tokens and ref_tokens:
            overlap  = pred_tokens & ref_tokens
            precision = len(overlap) / len(pred_tokens)
            recall    = len(overlap) / len(ref_tokens)
            if precision + recall > 0:
                token_f1 = 2 * precision * recall / (precision + recall)
 
        return {"rouge_l": rouge_l, "bert_f1": bert_f1, "token_f1": token_f1}
 
    # ── Public API ────────────────────────────────────────────────────────────
 
    def run(
        self,
        queries: List[str],
        references: Optional[List[str]] = None,
    ) -> List[RAGResult]:
        """
        Run the adaptive RAG pipeline over a list of queries.
 
        Parameters
        ----------
        queries    : list of query strings
        references : optional list of ground-truth answers (for evaluation)
 
        Returns
        -------
        List[RAGResult]
        """
        results = []
 
        for i, query in enumerate(queries):
            # ── Step 1: QPP score ─────────────────────────────────────────
            qpp_score = self._predict_qpp(query)
 
            # ── Step 2: Adaptive policy A(q) = (k(q), λ(q)) ──────────────
            k_q      = compute_k(qpp_score, self.k_min, self.k_max)
            lambda_q = compute_lambda(qpp_score)
            influence = lambda_to_influence(lambda_q)
 
            logger.info(
                "Query %d/%d | QPP=%.4f | k=%d | λ=%.4f (%s)",
                i + 1, len(queries), qpp_score, k_q, lambda_q, influence,
            )
 
            # ── Step 3: Retrieve top-k(q) passages ───────────────────────
            retrieved = self.retriever.retrieve(query, top_k=k_q)
            context   = "\n\n".join(r["text"] for r in retrieved)
 
            # ── Step 4: Build λ-conditioned prompt ───────────────────────
            prompt = build_prompt(query, context, lambda_q)
 
            # ── Step 5: Generate answer ───────────────────────────────────
            answer = self.generator.generate(prompt)
 
            # ── Step 6: Evaluate (if reference available) ─────────────────
            metrics = {"rouge_l": 0.0, "bert_f1": 0.0, "token_f1": 0.0}
            if references is not None and i < len(references):
                ref = references[i]
                if ref:
                    metrics = self._evaluate(answer, ref)
 
            results.append(RAGResult(
                query            = query,
                qpp_score        = qpp_score,
                k_used           = k_q,
                lambda_q         = lambda_q,
                context_influence = influence,
                answer           = answer,
                rouge_l          = metrics["rouge_l"],
                bert_f1          = metrics["bert_f1"],
                token_f1         = metrics["token_f1"],
            ))
 
        return results
 
