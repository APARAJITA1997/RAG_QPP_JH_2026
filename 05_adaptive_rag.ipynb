# adaptive_rag.py
# Runs the full QPP-guided RAG pipeline with adaptive policy A(q) = (k(q), lambda(q))
# k(q)      -> how many passages to retrieve for query q
# lambda(q) -> how much the retrieved context should influence the final answer

import logging
import math
from dataclasses import dataclass
from typing import Callable, List, Optional

import numpy as np

log = logging.getLogger(__name__)

# tunable constants -- change these to experiment with different depth ranges
SIGMOID_STEEPNESS = 6.0
K_FLOOR = 5
K_CEIL  = 20

# cutoffs that separate the three generation modes
HIGH_THRESH   = 0.66
LOW_THRESH    = 0.33


@dataclass
class QueryResult:
    query:      str
    qpp_score:  float
    k_used:     int
    lambda_val: float   # context-influence weight derived from QPP score
    gen_mode:   str     # STRONG / BALANCED / WEAK  (reflects lambda regime)
    answer:     str
    rouge_l:    float = 0.0
    bert_f1:    float = 0.0
    token_f1:   float = 0.0


def score_to_lambda(s, steepness=SIGMOID_STEEPNESS):
    # sigmoid centred at 0.5 so that s=0.5 gives lambda=0.5 (neutral)
    # high QPP score -> lambda near 1 (trust retrieval)
    # low  QPP score -> lambda near 0 (rely on model's own knowledge)
    return 1.0 / (1.0 + math.exp(-steepness * (s - 0.5)))


def score_to_k(s, lo=K_FLOOR, hi=K_CEIL):
    # linearly map QPP score onto [lo, hi] and round to integer
    return lo + round((hi - lo) * float(s))


def get_gen_mode(lam):
    if lam >= HIGH_THRESH:
        return "STRONG"
    elif lam >= LOW_THRESH:
        return "BALANCED"
    return "WEAK"


def make_prompt(query, passages, lam):
    # The wording of the instruction changes based on lambda.
    # This is how lambda(q) concretely affects generation:
    # the generator receives a different instruction depending on
    # how reliable the retrieval is estimated to be.

    mode = get_gen_mode(lam)

    if mode == "STRONG":
        # QPP score was high -> retrieval is likely good -> lean on the passages
        lead = (
            "The passages below are estimated to be highly relevant to this question. "
            "Build your answer mainly from them."
        )
    elif mode == "BALANCED":
        # QPP score was moderate -> treat passages as partial evidence
        lead = (
            "The passages below may cover the question partially. "
            "Draw on them where useful and fill gaps with your own knowledge."
        )
    else:
        # QPP score was low -> retrieval may be off-topic -> fall back on parametric knowledge
        lead = (
            "Retrieval quality for this question is estimated to be low. "
            "Answer from your own knowledge and treat the passages as background only."
        )

    return (
        f"{lead}\n\n"
        f"Retrieved context (lambda={lam:.3f}):\n{passages}\n\n"
        f"Question: {query}\nAnswer:"
    )


class AdaptiveRAGPipeline:
    """
    Wraps retriever + generator + QPP model into one pipeline.

    For every query:
      1. Run QPP to get a score s.
      2. Compute k(q) and lambda(q) from s.
      3. Retrieve k(q) passages.
      4. Build a lambda-conditioned prompt.
      5. Generate and (optionally) score the answer.
    """

    def __init__(self, retriever, generator, qpp_model,
                 scaler=None, df_lookup=None, corpus_lm=None,
                 encode_query_fn=None, k_lo=K_FLOOR, k_hi=K_CEIL):

        self.retriever      = retriever
        self.generator      = generator
        self.qpp_model      = qpp_model
        self.scaler         = scaler
        self.df_lookup      = df_lookup  or {}
        self.corpus_lm      = corpus_lm  or {}
        self.encode_query   = encode_query_fn
        self.k_lo           = k_lo
        self.k_hi           = k_hi

    def _get_qpp_score(self, query):
        from src.features import extract_features_batch

        # pull max passages for feature extraction, then let k(q) decide how many to use
        hits  = self.retriever.retrieve(query, top_k=self.k_hi)
        texts = [h["text"]      for h in hits]
        embs  = np.stack([h["embedding"] for h in hits])
        q_vec = self.encode_query(query) if self.encode_query else np.zeros(768, dtype=np.float32)

        X = extract_features_batch(
            [query], [texts], [embs],
            q_vec[np.newaxis, :],
            self.df_lookup, self.corpus_lm
        )
        if self.scaler is not None:
            X = self.scaler.transform(X)

        raw = float(self.qpp_model.predict(X)[0])
        return float(np.clip(raw, 0.0, 1.0))

    def _score_answer(self, pred, ref):
        rl = bf = tf = 0.0

        try:
            from rouge_score import rouge_scorer
            rl = rouge_scorer.RougeScorer(["rougeL"], use_stemmer=True)\
                             .score(ref, pred)["rougeL"].fmeasure
        except Exception:
            pass

        try:
            from bert_score import score as bs
            _, _, F = bs([pred], [ref], lang="en", verbose=False)
            bf = float(F[0])
        except Exception:
            pass

        p_tok = set(pred.lower().split())
        r_tok = set(ref.lower().split())
        if p_tok and r_tok:
            common = p_tok & r_tok
            pr = len(common) / len(p_tok)
            rc = len(common) / len(r_tok)
            if pr + rc > 0:
                tf = 2 * pr * rc / (pr + rc)

        return {"rouge_l": rl, "bert_f1": bf, "token_f1": tf}

    def run(self, queries: List[str], references: Optional[List[str]] = None) -> List[QueryResult]:

        out = []

        for idx, q in enumerate(queries):

            s      = self._get_qpp_score(q)
            k      = score_to_k(s, self.k_lo, self.k_hi)
            lam    = score_to_lambda(s)
            mode   = get_gen_mode(lam)

            log.info("[%d/%d] QPP=%.4f  k=%d  lambda=%.4f  mode=%s",
                     idx + 1, len(queries), s, k, lam, mode)

            hits    = self.retriever.retrieve(q, top_k=k)
            context = "\n\n".join(h["text"] for h in hits)
            prompt  = make_prompt(q, context, lam)
            answer  = self.generator.generate(prompt)

            metrics = {"rouge_l": 0.0, "bert_f1": 0.0, "token_f1": 0.0}
            if references and idx < len(references) and references[idx]:
                metrics = self._score_answer(answer, references[idx])

            out.append(QueryResult(
                query      = q,
                qpp_score  = s,
                k_used     = k,
                lambda_val = lam,
                gen_mode   = mode,
                answer     = answer,
                **metrics
            ))

        return out
 
