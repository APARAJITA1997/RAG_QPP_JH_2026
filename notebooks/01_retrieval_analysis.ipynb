import sys, os
sys.path.insert(0, os.path.abspath('..'))

import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
from pathlib import Path
import warnings
warnings.filterwarnings('ignore')

from src.evaluate import compute_retrieval_metrics

# ── Plot style
sns.set_theme(style='whitegrid', font_scale=1.1)
COLORS = {
    'BM25 (Sparse)':              '#E53935',
    'Sentence-BERT (Dense)':      '#1E88E5',
    'Hybrid (BM25 + Dense)':      '#43A047',
    'ColBERT (Late Interaction)': '#FB8C00',
}
Path('../outputs/figures').mkdir(parents=True, exist_ok=True)

# ── Load pre-computed relevance judgements from run files
# Each .npy file: shape (n_queries, list_len), values 0/1 (relevant at rank k)
DATA_DIR = Path('../data/retrieval_runs')

RETRIEVERS = {
    'BM25 (Sparse)':              np.load(DATA_DIR / 'bm25_rel_lists.npy'),
    'Sentence-BERT (Dense)':      np.load(DATA_DIR / 'sbert_rel_lists.npy'),
    'Hybrid (BM25 + Dense)':      np.load(DATA_DIR / 'hybrid_rel_lists.npy'),
    'ColBERT (Late Interaction)': np.load(DATA_DIR / 'colbert_rel_lists.npy'),
}

# ── Compute metrics from actual retrieval runs
records = []
for ret_name, rel_lists in RETRIEVERS.items():
    m = compute_retrieval_metrics(rel_lists, mrr_cutoffs=(5, 10, 20, 50), ndcg_cutoffs=(10, 100))
    m['Retriever'] = ret_name
    records.append(m)

df_all = pd.DataFrame(records).set_index('Retriever')

# ── Table 2: MRR
df_mrr = df_all[['MRR@5', 'MRR@10', 'MRR@20', 'MRR@50']]
print("=== Table 2: MRR ===")
print(df_mrr.round(3))

# ── Table 3: nDCG & AP
df_table3 = df_all[['nDCG@10', 'nDCG@100', 'AP']]
print("\n=== Table 3: nDCG & AP ===")
print(df_table3.round(3))

# ── Figure 1: MRR curves + bar chart
fig, axes = plt.subplots(1, 2, figsize=(14, 5))

ax = axes[0]
for ret_name in RETRIEVERS:
    values = [df_mrr.loc[ret_name, f'MRR@{k}'] for k in [5, 10, 20, 50]]
    ax.plot([5, 10, 20, 50], values, marker='o', label=ret_name,
            color=COLORS[ret_name], linewidth=2)
ax.set_xlabel('Cutoff (@k)')
ax.set_ylabel('MRR')
ax.set_title('MRR at Multiple Cutoffs')
ax.set_xticks([5, 10, 20, 50])
ax.legend(fontsize=9)

ax2 = axes[1]
metrics_to_plot = ['nDCG@10', 'nDCG@100', 'AP']
x = np.arange(len(metrics_to_plot))
width = 0.2
offsets = np.linspace(-1.5, 1.5, 4) * width
for i, ret_name in enumerate(RETRIEVERS):
    ax2.bar(x + offsets[i],
            [df_table3.loc[ret_name, m] for m in metrics_to_plot],
            width, label=ret_name, color=COLORS[ret_name], edgecolor='white')
ax2.set_xticks(x)
ax2.set_xticklabels(metrics_to_plot)
ax2.set_ylabel('Score')
ax2.set_title('nDCG & AP across Retrievers')
ax2.legend(fontsize=9)

plt.suptitle('RQ1: Retrieval-Level Behavior', fontsize=13)
plt.tight_layout()
plt.savefig('../outputs/figures/rq1_retrieval_metrics.png', dpi=150, bbox_inches='tight')
plt.show()

# ── Figure 2: MRR@10 heatmap across datasets
# CSV rows = retrievers, columns = datasets, values = MRR@10
MRR10_ALL = pd.read_csv(DATA_DIR / 'mrr10_all_datasets.csv', index_col=0)

plt.figure(figsize=(9, 4))
sns.heatmap(MRR10_ALL, annot=True, fmt='.3f', cmap='YlOrRd',
            linewidths=0.5, linecolor='white', cbar_kws={'label': 'MRR@10'})
plt.title('MRR@10 across Retrievers and Datasets')
plt.tight_layout()
plt.savefig('../outputs/figures/rq1_mrr10_heatmap.png', dpi=150, bbox_inches='tight')
plt.show()

# ── Key finding: query-level variance
variances = {name: np.var([r.mean() for r in rel_lists])
             for name, rel_lists in RETRIEVERS.items()}
print("\nVariance across queries (lower = more consistent):")
for name, var in variances.items():
    print(f"  {name}: {var:.4f}")
